        <mxCell id="note-cicd" parent="1" style="shape=mxgraph.aws4.note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=10;align=left;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;CI/CD Flow:&lt;/b&gt; CodeCommit triggers CodePipeline.&#xa;CodePipeline uses CodeBuild to run tests,&#xa;build the Docker image and push to ECR.&#xa;SSM Agent deploys updated container to EC2.&#xa;SNS notifications sent on success / failure." vertex="1">
          <mxGeometry height="110" width="310" x="1460" y="860" as="geometry" />
        </mxCell>
        <mxCell id="note-cdn" parent="1" style="shape=mxgraph.aws4.note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#FFFDE7;strokeColor=#F9A825;fontSize=10;align=left;spacingLeft=6;spacingTop=4;" value="&lt;b&gt;Delivery Flow:&lt;/b&gt; Internet Users access CloudFront.&#xa;CloudFront serves cached content and&#xa;forwards cache-misses through the IGW&#xa;to the EC2-hosted Docker container.&#xa;SSL is terminated at CloudFront." vertex="1">
          <mxGeometry height="110" width="310" x="1460" y="140" as="geometry" />
        </mxCell>
