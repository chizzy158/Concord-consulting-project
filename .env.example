# ─────────────────────────────────────────────────────────────
# Concord Consulting — .env.example
# SAFE TEMPLATE. Copy this to .env and fill in your real values.
# NEVER commit .env to Git or CodeCommit.
# ─────────────────────────────────────────────────────────────

# Server port (3000 is the default used in Dockerfile)
PORT=3000

# ── Database credentials ──────────────────────────────────────
# These come from the Terraform output after running terraform apply:
#   rds_endpoint = "concord-consulting-db.xxxxxxx.eu-west-1.rds.amazonaws.com"
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_USER=concordconsulting_admin
DB_PASS=your-strong-password-here
DB_NAME=concordconsultingdb
